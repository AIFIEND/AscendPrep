# ======================
# DECA Practice App Environment Configuration
# Copy this file to .env (backend) and .env.local (frontend), then replace placeholder values.
# ======================

# ----------------------
# Backend (Flask)
# ----------------------
SECRET_KEY=change-this-to-a-long-random-secret
SQLALCHEMY_DATABASE_URI=postgresql://deca_user:deca_pass@localhost:5432/deca_app
FRONTEND_ORIGIN=http://localhost:3000
# For Vercel previews, wildcard patterns are supported (example):
# FRONTEND_ORIGIN=https://deca-practice-app.vercel.app,https://deca-practice-app-*.vercel.app
FLASK_ENV=production
# Strongly recommended in production so first superadmin setup is protected.
SUPERADMIN_BOOTSTRAP_TOKEN=replace-with-a-strong-one-time-bootstrap-token

# ----------------------
# Frontend (Next.js / NextAuth)
# ----------------------
NEXT_PUBLIC_API_URL=http://localhost:5000
# Server-side API URL used by Next.js (e.g. Docker internal network)
API_URL=http://backend:5000
NEXTAUTH_URL=http://localhost:3000
NEXTAUTH_SECRET=replace-with-a-long-random-nextauth-secret
NODE_ENV=production
